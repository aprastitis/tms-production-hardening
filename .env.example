# PostgreSQL — used by both the db service and the app's DATABASE_URL
POSTGRES_USER=tms
POSTGRES_PASSWORD=tms_dev_password
POSTGRES_DB=tms

# App's Postgres DSN. The host is "db" because the app runs inside
# docker compose; use "localhost" if running the app outside compose.
DATABASE_URL=postgresql+psycopg://tms:tms_dev_password@db:5432/tms

# REQUIRED — must be set to a real, non-empty value that is NOT "changeme".
# The app refuses to start if this is unset, empty, whitespace, or "changeme".
SECRET_KEY=replace-me-with-a-real-secret